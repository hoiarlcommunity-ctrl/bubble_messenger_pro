NODE_ENV=production
APP_NAME=Bubble Messenger Pro
PORT=3000
PUBLIC_URL=http://localhost:3000

# Generate strong secrets before production:
# openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_access_secret_64_chars_minimum
JWT_REFRESH_SECRET=change_me_refresh_secret_64_chars_minimum
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
COOKIE_SECURE=false

DATABASE_URL=postgres://bubble:bubble_password@postgres:5432/bubble_messenger
REDIS_URL=redis://redis:6379

UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_MB=80
MAX_VOICE_SECONDS=300
MAX_VIDEO_SECONDS=90

CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240
AUTH_RATE_LIMIT_MAX=20

# Demo users are disabled by default for production-like launch.
# Set DEMO_USER=true only for local testing.
DEMO_USER=false
DEMO_USERNAME=demo
DEMO_PASSWORD=demo123
DEMO_DISPLAY_NAME=Demo User

# Optional: create your own first administrator automatically on first startup.
# Fill these before first launch if you need access to the admin panel.
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_DISPLAY_NAME=Administrator


# === V5 security/account settings ===
REGISTRATION_OPEN=true
REQUIRE_EMAIL_VERIFICATION=true
EMAIL_TOKEN_TTL_MINUTES=1440
PASSWORD_RESET_TTL_MINUTES=60
# Optional anti-bot protection. If HCAPTCHA_SECRET is set, registration requires captchaToken from frontend integration.
HCAPTCHA_SECRET=
HCAPTCHA_SITE_KEY=

# SMTP. If SMTP_HOST is empty, emails are written to ./data/dev-mails inside the app container.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=Bubble Messenger <no-reply@example.com>
DEV_MAIL_DIR=/app/data/dev-mails

# === Media storage ===
# Recommended for production-like Docker launch: s3 with MinIO.
# For simple local-only launch use: STORAGE_DRIVER=local
STORAGE_DRIVER=s3
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=bubble-media
S3_ACCESS_KEY=bubble
S3_SECRET_KEY=bubble_minio_password_change_me
S3_FORCE_PATH_STYLE=true
S3_PREFIX=uploads

# === WebRTC TURN/STUN ===
WEBRTC_STUN_URLS=stun:stun.l.google.com:19302
WEBRTC_TURN_URLS=turn:localhost:3478?transport=udp,turn:localhost:3478?transport=tcp
TURN_REALM=localhost
TURN_USERNAME=bubbleturn
TURN_PASSWORD=bubble_turn_password_change_me
TURN_CREDENTIAL=bubble_turn_password_change_me
